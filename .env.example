# Required for model calls
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen3-max

# Vision model backend
VISION_BACKEND=local_hf
VISION_MODEL_NAME=
LOCAL_VISION_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct
LOCAL_VISION_MODEL_DIR=./models/Qwen2.5-VL-7B-Instruct
LOCAL_VISION_DEVICE=auto
LOCAL_VISION_DTYPE=float16
LOCAL_VISION_LOAD_IN_4BIT=true
LOCAL_VISION_MAX_NEW_TOKENS=240
LOCAL_VISION_MAX_IMAGE_PIXELS=786432
MODEL_TIMEOUT_SECONDS=18
RUN_TIMEOUT_SECONDS=45
UPLOAD_MAX_IMAGE_BYTES=5000000
UPLOAD_MAX_IMAGE_COUNT=3
LOG_LEVEL=INFO
APP_ENV=dev

# Optional: LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_OTEL_ENABLED=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=do-or-not-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=

# Optional: web research
TAVILY_API_KEY=your-tavily-api-key
SQLITE_DB_PATH=./data/do_or_not.db
CHECKPOINT_DB_PATH=./data/checkpoints.db
UPLOADS_DIR=./data/uploads
SECRET_KEY=change-me
DEFAULT_USER_ID=local-user
